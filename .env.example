# Copy to .env and fill in your values (never commit .env)
# cp .env.example .env

BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true

# Coins to trade (one or more, comma-separated). Max 4 positions total.
# Default if not set: BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,BNBUSDT
# TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,BNBUSDT
# MAX_OPEN_POSITIONS=4

LEVERAGE=10
CAPITAL_PERCENT=15
MIN_SCORE=50
MARGIN_TYPE=CROSSED

# Daily loss limit: 0 = unlimited (never pause). e.g. 5 = pause if daily loss > 5%
# DAILY_LOSS_LIMIT=0

# Quick profit mode: close entire position when profit reaches this (USD). No TP1 partial - just $15 and quit.
# TAKE_PROFIT_USD=15
# Set 0 to use normal TP1/TP2/TP3 and trailing SL instead.

# Target ~50 trades/day (relaxed signals). Cap at 50 in 24h.
# MAX_TRADES_PER_DAY=50
# MIN_CONFIDENCE=52
# ML_MIN_TEST_ACCURACY=0.48
# Set MAX_TRADES_PER_DAY=0 for no cap.

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Optional advanced Telegram
# TG_RATE_LIMIT_PER_MINUTE=20
# TG_INLINE_BUTTONS=true
# TG_CONFIRM_TRADES=false
